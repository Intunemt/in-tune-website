---
title: "Resources"
layout: "default.njk"
---

<h1>Resources</h1>

<ul>
  {% for post in collections.resources %}
    <li>
      <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      {% if post.data.description %}
        <p>{{ post.data.description }}</p>
      {% endif %}
      <small>{{ post.date | date("MMMM d, yyyy") }}</small>
    </li>
  {% endfor %}
</ul>